      {
        "pagePath": "pages/balance/balance",
        "text": "课时",
        "iconPath": "static/icons/balance.png",
        "selectedIconPath": "static/icons/balance-active.png"
      },
      {
        "pagePath": "pages/schedule/schedule",
        "text": "排课",
        "iconPath": "static/icons/schedule.png",
        "selectedIconPath": "static/icons/schedule-active.png"
      }
