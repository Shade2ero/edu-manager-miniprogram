<view class="page">
  <!-- 月份选择器 -->
  <view class="month-picker">
    <view class="month-nav" bindtap="prevMonth">◀</view>
    <text class="month-label">{{currentMonth}}</text>
    <view class="month-nav" bindtap="nextMonth">▶</view>
  </view>

  <!-- 统计条 -->
  <view class="summary-bar">
    <view class="sum-item"><text class="sum-num">{{schedules.length}}</text><text class="sum-lbl">排课数</text></view>
    <view class="sum-item"><text class="sum-num sum-ok">{{totalCheckedIn}}</text><text class="sum-lbl">已签到</text></view>
    <view class="sum-item"><text class="sum-num sum-warn">{{totalPending}}</text><text class="sum-lbl">待签到</text></view>
    <view class="sum-item"><text class="sum-num sum-err">{{totalAbsent}}</text><text class="sum-lbl">缺勤</text></view>
  </view>

  <!-- 排课卡片 -->
  <view wx:for="{{schedules}}" wx:key="scheduleId" class="card" data-item="{{item}}" bindtap="goRoster">
    <view class="card-date">
      <text class="date-day">{{item._day}}</text>
      <text class="date-wd">{{item._weekday}}</text>
    </view>
    <view class="card-body">
      <view class="card-head">
        <text class="card-name">{{item.courseName}}</text>
        <view class="card-actions">
          <text class="card-tap" data-item="{{item}}" catchtap="showQrCode">出示二维码</text>
          <view class="card-del" wx:if="{{isStaff}}" data-sid="{{item.scheduleId}}" catchtap="deleteSchedule">✕</view>
        </view>
      </view>
      <view class="card-info">
        <text>🕐 {{item.startTime}}-{{item.endTime}}</text>
        <text>📍 {{item.classroom || '未指定'}}</text>
        <text>👨‍🏫 {{item.teacherName}}</text>
      </view>
      <view class="roster-summary" wx:if="{{item.totalStudents > 0}}">已签到 {{item.checkedInCount}}/{{item.totalStudents}} 人</view>
    </view>
  </view>

  <!-- 新建排课按钮 -->
  <view class="add-bar" wx:if="{{isStaff}}">
    <button class="add-btn" bindtap="showCreateForm">+ 新建排课</button>
  </view>

  <view wx:if="{{schedules.length === 0}}" class="empty">📅 本月暂无排课</view>

  <!-- 二维码弹窗 -->
  <view class="qr-mask" wx:if="{{showQr}}" bindtap="closeQr">
    <view class="qr-modal" catchtap>
      <view class="qr-header"><text class="qr-title">签到二维码</text><text class="qr-close" bindtap="closeQr">✕</text></view>
      <view class="qr-body">
        <text class="qr-course">{{qrCourseName}}</text>
        <text class="qr-time">{{qrTime}}</text>
        <image class="qr-image" src="{{qrImage}}" mode="aspectFit" />
        <text class="qr-hint">请学生使用微信扫一扫或小程序内扫码签到</text>
      </view>
      <view class="qr-footer">
        <button class="qr-btn qr-btn--refresh" bindtap="refreshQr">🔄 刷新二维码</button>
        <button class="qr-btn qr-btn--close" bindtap="closeQr">关闭</button>
      </view>
    </view>
  </view>

  <!-- 新建排课弹窗（时间选择器） -->
  <view class="qr-mask" wx:if="{{showCreate}}" bindtap="closeCreate">
    <view class="qr-modal" catchtap>
      <view class="qr-header"><text class="qr-title">新建排课</text><text class="qr-close" bindtap="closeCreate">✕</text></view>
      <view class="form-body">
        <view class="form-row">
          <text class="form-lbl">课程</text>
          <picker class="form-inp" mode="selector" range="{{courseList}}" range-key="courseName" value="{{courseIndex}}" bindchange="onCourseChange">
            <view class="form-picker-val">{{courseList[courseIndex].courseName || '请选择'}}</view>
          </picker>
        </view>
        <view class="form-row">
          <text class="form-lbl">日期</text>
          <picker class="form-inp" mode="date" value="{{form.date}}" bindchange="onDateChange">
            <view class="form-picker-val">{{form.date || '选择日期'}}</view>
          </picker>
        </view>
        <view class="form-row">
          <text class="form-lbl">时间</text>
          <picker class="form-inp" mode="time" value="{{form.start}}" bindchange="onStartTime">
            <view class="form-picker-val">{{form.start || '开始'}}</view>
          </picker>
          <text style="margin:0 12rpx">至</text>
          <picker class="form-inp" mode="time" value="{{form.end}}" bindchange="onEndTime">
            <view class="form-picker-val">{{form.end || '结束'}}</view>
          </picker>
        </view>
        <view class="form-row"><text class="form-lbl">教室</text><input class="form-inp" value="{{form.room}}" data-field="room" bindinput="onFormField" placeholder="A101"/></view>
      </view>
      <view class="qr-footer">
        <button class="qr-btn qr-btn--refresh" bindtap="doCreate">确认创建</button>
        <button class="qr-btn qr-btn--close" bindtap="closeCreate">取消</button>
      </view>
    </view>
  </view>
</view>
