.page { min-height:100vh; background:#F5F5F5; }

.month-picker { display:flex; align-items:center; justify-content:center; padding:24rpx; background:#fff; }
.month-nav { width:64rpx; height:64rpx; display:flex; align-items:center; justify-content:center; font-size:28rpx; color:#4A90D9; }
.month-label { font-size:32rpx; font-weight:600; color:#333; margin:0 32rpx; min-width:180rpx; text-align:center; }

.summary-bar { display:flex; margin:16rpx 24rpx; padding:24rpx; background:#fff; border-radius:16rpx; }
.sum-item { flex:1; text-align:center; }
.sum-num { font-size:36rpx; font-weight:700; color:#333; display:block; }
.sum-ok { color:#52C41A; } .sum-warn { color:#FAAD14; } .sum-err { color:#FF4D4F; }
.sum-lbl { font-size:22rpx; color:#999; }

.card { display:flex; margin:0 24rpx 16rpx; background:#fff; border-radius:16rpx; overflow:hidden; }
.card-date { width:100rpx; display:flex; flex-direction:column; align-items:center; justify-content:center; background:#F8FAFC; }
.date-day { font-size:36rpx; font-weight:700; color:#333; }
.date-wd { font-size:22rpx; color:#999; }
.card-body { flex:1; padding:20rpx; min-width:0; }
.card-head { display:flex; justify-content:space-between; align-items:center; }
.card-name { font-size:28rpx; font-weight:600; color:#333; }
.card-actions { display:flex; align-items:center; gap:16rpx; }
.card-tap { font-size:22rpx; color:#4A90D9; padding:6rpx 8rpx; }
.card-del { font-size:24rpx; color:#FF4D4F; padding:6rpx 10rpx; }

.add-bar { margin:0 24rpx 16rpx; }
.add-btn { width:100%; height:72rpx; background:#4A90D9; color:#fff; border-radius:16rpx; font-size:28rpx; border:none; padding:0; display:flex; align-items:center; justify-content:center; }

/* 新建排课表单 */
.form-body { padding:0 32rpx 24rpx; }
.form-row { display:flex; align-items:center; padding:12rpx 0; }
.form-lbl { width:100rpx; font-size:26rpx; color:#666; }
.form-inp { flex:1; height:64rpx; line-height:64rpx; border:1rpx solid #E5E5E5; border-radius:10rpx; padding:0 16rpx; font-size:26rpx; }
.form-picker-val { height:64rpx; line-height:64rpx; font-size:26rpx; color:#333; display:flex; align-items:center; }
.form-row { display:flex; align-items:center; padding:12rpx 0; }
.form-lbl { width:100rpx; font-size:26rpx; color:#666; line-height:64rpx; }
.card-info { display:flex; gap:16rpx; font-size:22rpx; color:#999; margin-top:8rpx; flex-wrap:wrap; }

.roster-summary { font-size:24rpx; color:#4A90D9; margin-top:12rpx; }

.empty { text-align:center; padding:120rpx 0; font-size:28rpx; color:#999; }

/* ====== 二维码弹窗 ====== */
.qr-mask { position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.6); display:flex; align-items:center; justify-content:center; z-index:999; }
.qr-modal { width:580rpx; background:#fff; border-radius:24rpx; overflow:hidden; }
.qr-header { display:flex; justify-content:space-between; align-items:center; padding:32rpx; }
.qr-title { font-size:34rpx; font-weight:700; color:#333; }
.qr-close { font-size:40rpx; color:#999; padding:8rpx; }
.qr-body { display:flex; flex-direction:column; align-items:center; padding:0 32rpx 32rpx; }
.qr-course { font-size:28rpx; font-weight:600; color:#333; margin-bottom:8rpx; }
.qr-time { font-size:24rpx; color:#999; margin-bottom:24rpx; }
.qr-image { width:400rpx; height:400rpx; border:2rpx solid #F0F0F0; border-radius:12rpx; }
.qr-hint { font-size:22rpx; color:#BBB; margin-top:20rpx; text-align:center; }
.qr-footer { display:flex; border-top:1rpx solid #F0F0F0; }
.qr-btn { flex:1; height:88rpx; line-height:88rpx; text-align:center; font-size:28rpx; border:none; border-radius:0; }
.qr-btn--refresh { background:#F0F5FF; color:#4A90D9; }
.qr-btn--close { background:#F5F5F5; color:#666; }
