.page { min-height:100vh; background:#F5F5F5; padding-bottom:200rpx; }

.header { padding:40rpx 32rpx 28rpx; background:linear-gradient(180deg,#e8f4fd,#f5f5f5); }
.header-title { font-size:40rpx; font-weight:700; color:#333; display:block; margin-bottom:8rpx; }
.header-sub { font-size:26rpx; color:#999; }
.admin-toggle { margin-top:16rpx; padding:10rpx 24rpx; background:rgba(255,255,255,0.9); border-radius:20rpx; font-size:24rpx; color:#FF4D4F; align-self:flex-start; display:inline-block; }
.card-status-tag { font-size:20rpx; padding:2rpx 10rpx; border-radius:8rpx; margin-right:8rpx; }
.tag-on { background:#F0FFF4; color:#52C41A; }
.tag-off { background:#FFF1F0; color:#FF4D4F; }
.card-toggle-btn { font-size:20rpx; color:#4A90D9; padding:2rpx 8rpx; }

/* 课程卡片 */
.course-card { margin:0 24rpx 24rpx; background:#fff; border-radius:20rpx; overflow:hidden; }
.card-cover { width:100%; height:200rpx; background:linear-gradient(135deg,#e8f4fd,#d4e8fb); display:flex; align-items:center; justify-content:center; font-size:72rpx; }
.card-body { padding:24rpx; }
.card-head { display:flex; justify-content:space-between; align-items:center; margin-bottom:12rpx; }
.card-name { font-size:32rpx; font-weight:600; color:#333; }
.card-category { font-size:22rpx; color:#4A90D9; background:rgba(74,144,217,0.1); padding:4rpx 16rpx; border-radius:12rpx; }
.card-desc { font-size:24rpx; color:#999; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }

/* 课时包 */
.pkg-list { margin-top:20rpx; display:flex; flex-direction:column; gap:16rpx; }
.pkg-item { display:flex; justify-content:space-between; align-items:center; padding:24rpx; border:2rpx solid #F0F0F0; border-radius:16rpx; }
.pkg-item--selected { border-color:#4A90D9; background:rgba(74,144,217,0.05); }
.pkg-name { font-size:28rpx; font-weight:500; color:#333; display:block; }
.pkg-hours { font-size:24rpx; color:#666; margin-top:4rpx; display:block; }
.pkg-valid { font-size:22rpx; color:#BBB; display:block; }
.pkg-price { display:flex; flex-direction:column; align-items:flex-end; }
.pkg-currency { font-size:24rpx; color:#FF4D4F; font-weight:600; }
.pkg-amount { font-size:36rpx; color:#FF4D4F; font-weight:700; }
.pkg-original { font-size:22rpx; color:#BBB; text-decoration:line-through; }
.pkg-btn { margin-top:8rpx; padding:6rpx 24rpx; border-radius:24rpx; font-size:22rpx; color:#4A90D9; border:1rpx solid #4A90D9; }

/* 底部栏 */
.bottom-bar { position:fixed; bottom:calc(90rpx + env(safe-area-inset-bottom)); left:0; right:0; padding:16rpx 24rpx; background:#fff; border-top:1rpx solid #F0F0F0; z-index:100; }
.bottom-main { width:100%; }
.bottom-course { font-size:26rpx; color:#333; font-weight:500; display:block; margin-bottom:12rpx; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.bottom-row { display:flex; align-items:center; }
.bottom-label { font-size:22rpx; color:#999; padding:4rpx 12rpx; background:#F5F5F5; border-radius:8rpx; margin-right:12rpx; }
.bottom-price { font-size:32rpx; font-weight:700; color:#FF4D4F; flex:1; }
.bottom-btn { width:180rpx; height:72rpx; background:linear-gradient(135deg,#4A90D9,#5BA0E8); color:#fff; border-radius:36rpx; font-size:28rpx; font-weight:600; border:none; padding:0; display:flex; align-items:center; justify-content:center; }

/* 弹窗 */
.modal-mask { position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); display:flex; align-items:center; justify-content:center; z-index:999; }
.confirm-modal { width:600rpx; background:#fff; border-radius:24rpx; overflow:hidden; }
.confirm-head { display:flex; justify-content:space-between; padding:32rpx; border-bottom:1rpx solid #F0F0F0; }
.confirm-title { font-size:32rpx; font-weight:600; }
.confirm-close { font-size:36rpx; color:#999; }
.confirm-body { padding:32rpx; }
.confirm-row { display:flex; justify-content:space-between; padding:12rpx 0; font-size:26rpx; }
.confirm-lbl { color:#999; }
.confirm-hl { color:#4A90D9; font-weight:600; }
.confirm-div { height:1rpx; background:#F0F0F0; margin:16rpx 0; }
.confirm-total { font-size:36rpx; font-weight:700; color:#FF4D4F; }
.confirm-footer { display:flex; border-top:1rpx solid #F0F0F0; }
.btn-cancel, .btn-pay { flex:1; height:88rpx; line-height:88rpx; text-align:center; font-size:28rpx; border:none; border-radius:0; }
.btn-cancel { background:#F5F5F5; color:#666; }
.btn-pay { background:linear-gradient(135deg,#07C160,#06AD56); color:#fff; }
.btn-mock { flex:1; height:88rpx; line-height:88rpx; text-align:center; font-size:26rpx; border:none; background:#FFF7E6; color:#D48806; border-top:1rpx solid #FFE58F; }

/* 结果弹窗 */
.result-modal { width:560rpx; background:#fff; border-radius:24rpx; padding:48rpx 36rpx 36rpx; display:flex; flex-direction:column; align-items:center; }
.result-icon { font-size:72rpx; margin-bottom:20rpx; }
.result-title { font-size:34rpx; font-weight:700; color:#333; margin-bottom:16rpx; }
.result-desc { font-size:26rpx; color:#666; text-align:center; margin-bottom:32rpx; }
.result-btn { width:360rpx; height:80rpx; line-height:80rpx; background:linear-gradient(135deg,#4A90D9,#5BA0E8); color:#fff; border-radius:12rpx; font-size:28rpx; border:none; }

.empty { text-align:center; padding:120rpx 0; font-size:28rpx; color:#999; }

/* 管理员操作 */
.admin-actions { display:flex; align-items:center; gap:8rpx; }
.act-btn { font-size:20rpx; color:#4A90D9; padding:2rpx 10rpx; }
.act-del { color:#FF4D4F; }

/* 新增表单 */
.add-bar { margin:0 24rpx 16rpx; }
.add-btn { width:100%; height:72rpx; background:#4A90D9; color:#fff; border-radius:16rpx; font-size:28rpx; border:none; padding:0; display:flex; align-items:center; justify-content:center; }

.form-body { padding:0 32rpx 24rpx; }
.form-row { display:flex; align-items:center; padding:10rpx 0; }
.form-lbl { width:130rpx; font-size:26rpx; color:#666; flex-shrink:0; }
.form-inp { flex:1; height:64rpx; line-height:64rpx; border:1rpx solid #E5E5E5; border-radius:10rpx; padding:0 16rpx; font-size:26rpx; }
.form-divider { display:flex; justify-content:space-between; align-items:center; font-size:26rpx; font-weight:600; color:#333; padding:16rpx 0 8rpx; border-top:1rpx solid #F0F0F0; margin-top:8rpx; }
.add-pkg-btn { font-size:24rpx; font-weight:400; color:#4A90D9; }

/* 课时包表单项 */
.pkg-form-item { background:#F8FAFC; border-radius:12rpx; padding:12rpx 16rpx; margin-bottom:12rpx; }
.pkg-form-hd { display:flex; justify-content:space-between; font-size:24rpx; color:#666; margin-bottom:8rpx; }
.pkg-del-btn { color:#FF4D4F; }

/* 管理按钮 */
.admin-actions { display:flex; align-items:center; gap:12rpx; }

/* 弹窗（复用排课页样式） */
.qr-modal { width:580rpx; background:#fff; border-radius:24rpx; overflow:hidden; }
.qr-header { display:flex; justify-content:space-between; align-items:center; padding:24rpx 32rpx; }
.qr-title { font-size:32rpx; font-weight:600; color:#333; }
.qr-close { font-size:36rpx; color:#999; padding:8rpx; }
.qr-footer { display:flex; border-top:1rpx solid #F0F0F0; }
.qr-btn { flex:1; height:88rpx; line-height:88rpx; text-align:center; font-size:28rpx; border:none; border-radius:0; }
.qr-btn--refresh { background:#F0F5FF; color:#4A90D9; }
.qr-btn--close { background:#F5F5F5; color:#666; }
