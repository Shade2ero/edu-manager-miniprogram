.page { min-height:100vh; background:linear-gradient(180deg,#e8f4fd 0%,#f5f5f5 40%); padding-bottom:env(safe-area-inset-bottom); }

.status-card { margin:24rpx; padding:32rpx; background:linear-gradient(135deg,#4A90D9,#5BA0E8); border-radius:24rpx; box-shadow:0 8rpx 24rpx rgba(74,144,217,0.3); }
.status-inner { display:flex; align-items:center; }
.status-icon { width:80rpx; height:80rpx; background:rgba(255,255,255,0.2); border-radius:20rpx; display:flex; align-items:center; justify-content:center; font-size:40rpx; margin-right:24rpx; }
.status-title { font-size:36rpx; font-weight:700; color:#fff; display:block; }
.status-desc { font-size:24rpx; color:rgba(255,255,255,0.8); margin-top:8rpx; display:block; }

.scan-area { display:flex; flex-direction:column; align-items:center; padding:60rpx 0; }
.scan-btn { width:320rpx; height:320rpx; background:#fff; border-radius:50%; display:flex; flex-direction:column; align-items:center; justify-content:center; box-shadow:0 8rpx 40rpx rgba(0,0,0,0.1); border:6rpx dashed #4A90D9; }
.scan-btn--loading { opacity:0.7; transform:scale(0.95); }
.scan-btn-icon { font-size:72rpx; margin-bottom:16rpx; }
.scan-btn-text { font-size:30rpx; font-weight:600; color:#333; }
.scan-btn-hint { font-size:22rpx; color:#999; margin-top:8rpx; }

.tips-card { margin:0 24rpx 40rpx; padding:28rpx; background:#fff; border-radius:16rpx; }
.tips-title { font-size:28rpx; font-weight:600; color:#333; margin-bottom:16rpx; }
.tips-item { font-size:24rpx; color:#666; line-height:2; }

/* 弹窗 */
.modal-mask { position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); display:flex; align-items:center; justify-content:center; z-index:999; }
.result-modal { width:600rpx; background:#fff; border-radius:24rpx; padding:48rpx 36rpx 36rpx; display:flex; flex-direction:column; align-items:center; }
.result-icon { font-size:80rpx; margin-bottom:20rpx; }
.result-title { font-size:34rpx; font-weight:700; margin-bottom:12rpx; }
.success-text { color:#333; }
.fail-text { color:#FF4D4F; }
.result-detail { width:100%; padding:24rpx; background:#F8FAFC; border-radius:16rpx; margin-bottom:24rpx; }
.detail-row { display:flex; justify-content:space-between; font-size:26rpx; padding:8rpx 0; color:#999; }
.detail-consume { color:#FF4D4F; font-weight:600; }
.detail-normal { color:#52C41A; font-weight:600; }
.detail-low { color:#FAAD14; font-weight:600; }
.detail-warn { margin-top:16rpx; padding:12rpx 16rpx; background:#FFF7E6; border-radius:8rpx; font-size:24rpx; color:#FAAD14; text-align:center; }
.result-reason { font-size:28rpx; color:#666; margin-bottom:24rpx; text-align:center; }
.result-btn { width:320rpx; height:80rpx; line-height:80rpx; background:linear-gradient(135deg,#4A90D9,#5BA0E8); color:#fff; border-radius:12rpx; font-size:28rpx; border:none; }
