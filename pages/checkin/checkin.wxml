<view class="page">
  <!-- 顶部状态卡 -->
  <view class="status-card">
    <view class="status-inner">
      <view class="status-icon">📱</view>
      <view class="status-text">
        <text class="status-title">扫码签到</text>
        <text class="status-desc">扫描教师端二维码完成签到，系统将自动扣除对应课时</text>
      </view>
    </view>
  </view>

  <!-- 扫码按钮 -->
  <view class="scan-area">
    <view class="scan-btn {{isCheckingIn ? 'scan-btn--loading' : ''}}" bindtap="handleScanCode">
      <text class="scan-btn-icon">📷</text>
      <text class="scan-btn-text">{{isCheckingIn ? '签到处理中...' : '点击扫码签到'}}</text>
      <text class="scan-btn-hint" wx:if="{{!isCheckingIn}}">请对准教师端展示的二维码</text>
    </view>
  </view>

  <!-- 签到须知 -->
  <view class="tips-card">
    <view class="tips-title">签到须知</view>
    <view class="tips-item">· 请在上课前30分钟至下课后30分钟内完成签到</view>
    <view class="tips-item">· 需开启定位权限，在机构范围内方可签到成功</view>
    <view class="tips-item">· 签到成功后系统将自动扣除1课时</view>
    <view class="tips-item">· 仅限本人使用，请勿替他人签到</view>
  </view>

  <!-- 结果弹窗 -->
  <view class="modal-mask" wx:if="{{showResult}}" bindtap="closeResult">
    <view class="result-modal" catchtap>
      <!-- 成功 -->
      <block wx:if="{{checkInResult.checkInSuccess}}">
        <view class="result-icon success">✅</view>
        <view class="result-title success-text">{{checkInResult.riskLevel === 'HIGH_RISK' ? '等待教师确认' : '签到成功'}}</view>
        <view class="result-detail" wx:if="{{checkInResult.consumptionTriggered}}">
          <view class="detail-row">
            <text>本次消耗</text>
            <text class="detail-consume">-{{checkInResult.consumedHours || 1}} 课时</text>
          </view>
          <view class="detail-row" wx:if="{{checkInResult.remainingHours !== null}}">
            <text>剩余课时</text>
            <text class="{{checkInResult.lowBalanceWarning ? 'detail-low' : 'detail-normal'}}">{{checkInResult.remainingHours}} 课时</text>
          </view>
          <view class="detail-warn" wx:if="{{checkInResult.lowBalanceWarning}}">⚠️ 课时即将用完，请及时续费</view>
        </view>
      </block>
      <!-- 失败 -->
      <block wx:else>
        <view class="result-icon fail">❌</view>
        <view class="result-title fail-text">签到失败</view>
        <view class="result-reason">{{checkInResult.displayMessage || '未知错误'}}</view>
      </block>
      <button class="result-btn" bindtap="closeResult">{{checkInResult.checkInSuccess ? '完成' : '知道了'}}</button>
    </view>
  </view>
</view>
