.tab-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  display: flex;
  background: #fff;
  border-top: 1rpx solid #eee;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0 12rpx;
  color: #999;
  font-size: 20rpx;
}

.tab-item--active {
  color: #4A90D9;
}

.tab-icon {
  font-size: 36rpx;
  margin-bottom: 2rpx;
}

.tab-text {
  font-size: 20rpx;
}
