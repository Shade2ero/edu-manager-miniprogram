<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="key"
    class="tab-item {{selected === index ? 'tab-item--active' : ''}}"
    data-index="{{index}}"
    data-path="{{item.pagePath}}"
    bindtap="switchTab"
  >
    <text class="tab-icon">{{item.icon}}</text>
    <text class="tab-text">{{item.text}}</text>
  </view>
</view>
